 {% assign product_tags_list = product.tags | join: ' ' %}
{% assign styleName = '' %}

{% if product_tags_list contains 'bootie-size-chart' %}
  {% assign styleName = 'Booties' %}
{% elsif product_tags_list contains 'boots-size-chart' %}
  {% assign styleName = 'Camping' %}
{% elsif product_tags_list contains 'high-top-size-chart' %}
  {% assign styleName = 'High' %}
{% elsif product_tags_list contains 'jogger-size-chart' %}
  {% assign styleName = 'Joggers' %}
{% elsif product_tags_list contains 'low-top-size-chart' %}
  {% assign styleName = 'Low Tops' %}
{% elsif product_tags_list contains 'kids-size-chart' %}
  {% assign styleName = 'Kids' %}
{% elsif product_tags_list contains 'runner-size-chart' %}
  {% assign styleName = 'Runners' %}
{% elsif product_tags_list contains 'slide-size-chart' %}
  {% assign styleName = 'Slides' %}
{% elsif product_tags_list contains 'slip-on-size-chart' %}
  {% assign styleName = 'Slip Ons' %}
{% elsif product_tags_list contains 'size-guide-buckle-sandals' %}
  {% assign styleName = 'Buckle sandals' %}
{% elsif product_tags_list contains 'size-guide-trekks' %}
  {% assign styleName = 'Trekk Boots' %}
{% elsif product_tags_list contains 'western-size-chart' %}
  {% assign styleName = 'Western Boots' %}
{% elsif product_tags_list contains 'coverups-size-chart' %}
  {% assign styleName = 'Cover Ups' %}
{% elsif product_tags_list contains 'tennis-size-chart' %}
  {% assign styleName = 'Runs' %}
{% elsif product_tags_list contains 'trainer-size-chart' %}
