<script>
(function () {
  /* Collect unique URLs across both price element types */
  var urls = {};
  document.querySelectorAll('.js-current-price, .js-compare-price').forEach(function (el) {
    var url = el.getAttribute('data-url');
    if (url) urls[url] = true;
  });

  Object.keys(urls).forEach(function (url) {
    fetch(url + '.json')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var variant = data.product && data.product.variants && data.product.variants[0];
        if (!variant) return;

        var price       = variant.price ? '$' + parseFloat(variant.price).toFixed(2) : null;
        var comparePrice = variant.compare_at_price ? '$' + parseFloat(variant.compare_at_price).toFixed(2) : null;

        document.querySelectorAll('.js-current-price[data-url="' + url + '"]').forEach(function (el) {
          if (price) el.textContent = price;
        });
        document.querySelectorAll('.js-compare-price[data-url="' + url + '"]').forEach(function (el) {
          if (comparePrice) el.textContent = comparePrice;
          else el.style.display = 'none';
        });
      })
      .catch(function () {});
  });
})();
</script>

<!-- =============================================
     GSAP — Premium scroll animations
     ============================================= -->
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
<script>
(function () {
  if (typeof gsap === 'undefined') return;

  gsap.registerPlugin(ScrollTrigger);

  /* ── Respect reduced motion ─────────────────── */
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduced) return;

  /* ── Helpers ─────────────────────────────────── */
  var E = 'power3.out';
  var E2 = 'power2.out';

  function scrollIn(targets, vars, triggerEl) {
    var el = triggerEl || (typeof targets === 'string' ? document.querySelector(targets) : targets[0]);
    if (!el) return;
    gsap.fromTo(targets,
      { autoAlpha: 0, y: vars.y || 28 },
      Object.assign({
        autoAlpha: 1, y: 0,
        duration: 0.75, ease: E,
        scrollTrigger: { trigger: el, start: 'top 88%', once: true }
      }, vars)
    );
  }

  function staggerIn(targets, staggerVal, triggerEl, extraVars) {
    var nodes = document.querySelectorAll(targets);
    if (!nodes.length) return;
    var el = triggerEl ? document.querySelector(triggerEl) : nodes[0];
    gsap.fromTo(nodes,
      { autoAlpha: 0, y: 26 },
      Object.assign({
        autoAlpha: 1, y: 0,
        duration: 0.7, ease: E,
        stagger: staggerVal || 0.1,
        scrollTrigger: { trigger: el, start: 'top 88%', once: true }
      }, extraVars || {})
    );
  }

  /* ── Set initial state for hero (above fold) ── */
  gsap.set([
    '.lp-hero__overline',
    '.lp-hero__heading',
    '.lp-hero__subheading',
    '.lp-hero__pricing',
    '.lp-hero__compare-row',
  ], { autoAlpha: 0, y: 24 });

  /* ── HERO — load timeline ─────────────────────── */
  var hero = gsap.timeline({ delay: 0.1, defaults: { ease: E } });
  hero
    .to('.lp-hero__overline',     { autoAlpha: 1, y: 0, duration: 0.6 })
    .to('.lp-hero__heading',      { autoAlpha: 1, y: 0, duration: 0.75 }, '-=0.35')
    .to('.lp-hero__subheading',   { autoAlpha: 1, y: 0, duration: 0.6  }, '-=0.45')
    .to('.lp-hero__pricing',      { autoAlpha: 1, y: 0, duration: 0.55 }, '-=0.35')
    .to('.lp-hero__compare-row',  { autoAlpha: 1, y: 0, duration: 0.55, stagger: 0.1 }, '-=0.3')

  /* ── BLOCKQUOTE ──────────────────────────────── */
  var bq = document.querySelector('.lp-blockquote');
  if (bq) {
    gsap.fromTo(
      [bq.querySelector('.lp-blockquote__text'), bq.querySelector('.lp-blockquote__cite')],
      { autoAlpha: 0, y: 22 },
      { autoAlpha: 1, y: 0, duration: 0.7, ease: E, stagger: 0.15,
        scrollTrigger: { trigger: bq, start: 'top 86%', once: true } }
    );
  }

  /* ── SECTION HEADING ─────────────────────────── */
  staggerIn('.lp-section-heading__title, .lp-section-heading__sub', 0.12, '.lp-section-heading');

  /* ── REASONS — each row ──────────────────────── */
  document.querySelectorAll('.lp-reasons__row').forEach(function (row) {
    var isReverse = row.classList.contains('lp-reasons__row--reverse');
    var img = row.querySelector('.lp-reasons__img-wrap');
    var contentEls = row.querySelectorAll('.lp-reasons__category, .lp-reasons__title-wrap, .lp-reasons__body, .lp-reasons__quote, .lp-reasons__specs');

    if (img) {
      gsap.fromTo(img,
        { autoAlpha: 0, x: isReverse ? 50 : -50 },
        { autoAlpha: 1, x: 0, duration: 0.9, ease: E,
          scrollTrigger: { trigger: row, start: 'top 85%', once: true } }
      );
    }
    if (contentEls.length) {
      gsap.fromTo(contentEls,
        { autoAlpha: 0, y: 22 },
        { autoAlpha: 1, y: 0, duration: 0.65, ease: E, stagger: 0.1,
          scrollTrigger: { trigger: row, start: 'top 85%', once: true, delay: 0.15 } }
      );
    }
  });

  /* ── REASONS CTA BARS ────────────────────────── */
  document.querySelectorAll('.lp-reasons__cta-bar').forEach(function (bar) {
    gsap.fromTo(
      bar.querySelector('.lp-reasons__cta-text'),
      { autoAlpha: 0, y: 16 },
      { autoAlpha: 1, y: 0, duration: 0.6, ease: E2, stagger: 0.12,
        scrollTrigger: { trigger: bar, start: 'top 90%', once: true } }
    );
  });


  /* ── REVIEWS ─────────────────────────────────── */
  var cards = document.querySelectorAll('.lp-review-card');
  if (cards.length) {
    gsap.fromTo(cards,
      { autoAlpha: 0, y: 30 },
      { autoAlpha: 1, y: 0, duration: 0.65, ease: E, stagger: { amount: 0.45 },
        scrollTrigger: { trigger: '.lp-reviews__grid', start: 'top 88%', once: true } }
    );
  }


  /* ── MINI CARD ───────────────────────────────── */
  var mc = document.querySelector('.lp-mini-card');
  if (mc) {
    gsap.fromTo(mc,
      { autoAlpha: 0, y: 36, scale: 0.97 },
      { autoAlpha: 1, y: 0, scale: 1, duration: 0.8, ease: E,
        scrollTrigger: { trigger: mc, start: 'top 88%', once: true } }
    );
  }

  /* ── FOOTER ──────────────────────────────────── */
  var ft = document.querySelector('.lp-footer__inner');
  if (ft) {
    gsap.fromTo(ft.children,
      { autoAlpha: 0, y: 16 },
      { autoAlpha: 1, y: 0, duration: 0.55, ease: E2, stagger: 0.1,
        scrollTrigger: { trigger: ft, start: 'top 95%', once: true } }
    );
  }

})();
</script>