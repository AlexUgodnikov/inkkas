        "quote_CyaMfC": {
          "type": "quote",
          "settings": {
            "stars": "5",
            "text": "\"I call these my 'happy shoes.' They are so fun and I get smiles and compliments everywhere. Super comfy and certainly want another pair! True to size as well!\"",
