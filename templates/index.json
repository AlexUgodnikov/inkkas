    "multicolumn_TW977r": {
      "type": "multicolumn",
      "blocks": {
        "column_XnYGQ9": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/making_of_the_joggers-ezgif.com-optiwebp.webp",
            "image_full_width": true,
            "retina": true,
            "title": "Ethically Handcrafted",
            "text": "<p>More than just a pair of shoes, we build experiences—for your feet and your soul. With artful designs and premium materials that are cushioned, lightweight, and mold to your movement, our shoes are made to move with you wherever the day takes you.</p>",
            "link_label": "Check Out The Blog",
            "link": "shopify://blogs/blog"
          }
        },
        "column_mwd9nj": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/BLAKE-SLIP-ON-KL302333-MODELZOOM-ART-IMG_7673.jpg",
            "image_full_width": true,
            "retina": true,
            "title": "Good for the Sole",
            "text": "<p>Since 2012, we’ve been designing shoes that don’t follow the crowd—because neither do you. Every design starts with original art <em><strong>inked</strong></em> by independent artists, inspired by nature around the world, crafted with bold colors and details you won’t find anywhere else. </p>",
            "link_label": "About Inkkas",
            "link": "shopify://pages/about"
          }
        },
        "column_f6TFFJ": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/Tree-square-update.jpg",
            "image_full_width": true,
            "retina": true,
            "title": "Every Purchase Plants a Tree",
            "text": "<p>We plant one tree for every purchase with trees.org, amounting to more than <strong>half a million trees </strong>planted as of 2026. To reduce waste, we make collections in small batches using time-honored techniques that are better for people & the planet.</p>",
            "link_label": "Learn More",
            "link": "shopify://pages/about"
          }
        }
      },
