    "testimonials_zhUtgi": {
      "type": "testimonials",
      "blocks": {
        "quote_CiTr6X": {
          "type": "quote",
          "settings": {
            "stars": "5",
            "text": "\"I feel like a celebrity in these comfy joggers. People stop me to compliment them daily and I just love them. They bring me joy in some weird shoe way.\"",
            "author": "Crimson"
          }
        },
        "quote_3Pe4wC": {
          "type": "quote",
          "settings": {
            "stars": "5",
            "text": "\"I’m in love. Comfortable, ridiculously stylish. Why I only bought neutral shoes and accessories now baffles me.\"",
            "author": "Laura M."
          }
        },
        "quote_CyaMfC": {
          "type": "quote",
          "settings": {
            "stars": "5",
            "text": "\"I call these my 'happy shoes.' They are so fun and I get smiles and compliments everywhere. Super comfy and certainly want another pair! True to size as well!\"",
            "author": "Kelsi C. "
          }
        },
        "quote_FmHYhn": {
          "type": "quote",
          "settings": {
            "stars": "5",
            "text": "\"These are phenomenal. Not only are they functional, but they are super cute! I am officially inspired to go hiking and exploring way more!\"",
            "author": "Carly B."
          }
        }
      },
