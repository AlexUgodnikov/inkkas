<script>
(function () {
  var box = document.querySelector('.lp-buybox');
  if (!box) return;

  var sizesRow = box.querySelector('.lp-buybox__sizes-row');
  var btn = box.querySelector('.lp-buybox__btn');
  if (!sizesRow || !btn) return;

  var href = btn.getAttribute('href') || '';
  var baseUrl = '/products/luzon-buckle-sandal';
  var match = href.match(/(?:variant=|\/cart\/)(\d+)/);
  var initialVariantId = match ? match[1] : null;

  fetch(baseUrl + '.json')
    .then(function (r) { return r.json(); })
    .then(function (data) {
      var variants = data.product && data.product.variants;
      if (!variants || !variants.length) return;

      sizesRow.innerHTML = '';
      var hasActive = false;

      variants.forEach(function (variant) {
        var btnEl = document.createElement('button');
        btnEl.type = 'button';
        btnEl.className = 'lp-buybox__size';
        btnEl.setAttribute('data-id', variant.id);
        btnEl.textContent = variant.title;

        var isActive = initialVariantId ? (String(variant.id) === String(initialVariantId)) : false;
        if (isActive) {
          btnEl.classList.add('lp-buybox__size--active');
          btn.setAttribute('href', '/cart/' + variant.id + ':1?discount=SUMMER20');
          hasActive = true;
        }

        btnEl.addEventListener('click', function () {
          sizesRow.querySelectorAll('.lp-buybox__size').forEach(function (s) {
            s.classList.remove('lp-buybox__size--active');
          });
          btnEl.classList.add('lp-buybox__size--active');
          btn.setAttribute('href', '/cart/' + variant.id + ':1?discount=SUMMER20');
        });

        sizesRow.appendChild(btnEl);
      });

      if (!hasActive && variants.length > 0) {
        var firstBtn = sizesRow.querySelector('.lp-buybox__size');
        if (firstBtn) {
          firstBtn.classList.add('lp-buybox__size--active');
          btn.setAttribute('href', '/cart/' + variants[0].id + ':1?discount=SUMMER20');
        }
      }
    })
    .catch(function (err) {
      console.error('Error loading variants:', err);
    });
})();
</script>


