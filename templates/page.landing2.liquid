<script>
(function () {
  var bar = document.querySelector('.lp-sticky-bar');
  if (!bar || !('IntersectionObserver' in window)) return;

  var watch = document.querySelectorAll('.lp-product-card__price-wrap, .lp-hero__content, .lp-buybox__price');
  if (!watch.length) return;

  var visible = new Set();

  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        visible.add(entry.target);
      } else {
        visible.delete(entry.target);
      }
    });
    bar.classList.toggle('is-hidden', visible.size > 0);
  }, { threshold: 0 });

  watch.forEach(function (el) { observer.observe(el); });
})();
</script>


<script>
(function () {
  /* Collect unique URLs across both price element types */
  var urls = {};
  document.querySelectorAll('.js-current-price, .js-compare-price, .js-discount-price').forEach(function (el) {
    var url = el.getAttribute('data-url');
    if (url) urls[url] = true;
  });

  Object.keys(urls).forEach(function (url) {
    fetch(url + '.json')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        var variant = data.product && data.product.variants && data.product.variants[0];
        if (!variant) return;

        var price       = variant.price ? '$' + parseFloat(variant.price).toFixed(2) : null;
        var comparePrice = variant.compare_at_price ? '$' + parseFloat(variant.compare_at_price).toFixed(2) : null;

        document.querySelectorAll('.js-current-price[data-url="' + url + '"]').forEach(function (el) {
          if (price) {
            el.textContent = price;

            // Calculate and display discount and discounted price (20%)
            var numPrice = parseFloat(variant.price);
            if (!isNaN(numPrice)) {
              var discountPercent = 0.20; // Hardcoded 20%
              var savedAmount = numPrice * discountPercent;
              var discountedPrice = numPrice - savedAmount;

              var parent = el.parentElement;
              if (parent) {
                var discountEl = parent.querySelector('.js-discount');
                if (discountEl) {
                  discountEl.textContent = 'Save $' + savedAmount.toFixed(2);
                }
                var discountPriceEl = parent.querySelector('.js-discount-price');
                if (discountPriceEl) {
                  discountPriceEl.textContent = '$' + discountedPrice.toFixed(2);
                }
              }
            }
          }
        });
        document.querySelectorAll('.js-compare-price[data-url="' + url + '"]').forEach(function (el) {
          if (comparePrice) el.textContent = comparePrice;
          else el.style.display = 'none';
        });
      })
      .catch(function () {});
  });
})();
</script>

<script>
(function () {
  
  var linkSelectors = '.lp-sticky-bar__btn,.lp-hero__btn, .lp-inline-cta__btn, .lp-finalbuy__btn,.lp-announcement-bar__link, .lp-closing__btn';

  var target = document.querySelector('.lp-buybox__price');
  if (!target) return;

  document.querySelectorAll(linkSelectors).forEach(function (el) {
    el.addEventListener('click', function (e) {
      e.preventDefault();
      var top = target.getBoundingClientRect().top + window.pageYOffset;
      window.scrollTo({ top: top, behavior: 'smooth' });
    });
  });
})();
</script>

